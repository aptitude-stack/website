{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "REGISTRY_BASE_URL": "@registry-base-url",
    "REGISTRY_READ_TOKEN": "@registry-read-token"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
