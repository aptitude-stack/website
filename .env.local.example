# Base URL of the seeded local registry API (no trailing slash).
# Start it from ../registry with `make run-dev`.
REGISTRY_BASE_URL=http://127.0.0.1:8000

# Dev registry bearer token: <token_id>.<token_secret>
# Used server-side only — never exposed to the browser.
REGISTRY_READ_TOKEN=reader-token.dev-reader-secret

# Dev registry telemetry bearer token used by /api/star-events.
# Used server-side only — never exposed to the browser.
REGISTRY_TELEMETRY_TOKEN=telemetry-token.dev-telemetry-secret

# Operator login password. Optional in local development; when omitted locally,
# the dev-only password is "aptitude-dev". Required in production.
APTITUDE_OPERATOR_PASSWORD=change_me_locally

# HMAC secret for the operator session cookie. Optional in local development;
# required in production. Use a long random value.
APTITUDE_SESSION_SECRET=change_me_to_a_long_random_value

# In local development, the website also falls back to these registry values
# when REGISTRY_BASE_URL, REGISTRY_READ_TOKEN, and REGISTRY_TELEMETRY_TOKEN are omitted.
