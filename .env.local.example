# Base URL of the registry API (no trailing slash)
REGISTRY_BASE_URL=https://api.aptitude-registry.dev

# Registry bearer token: <token_id>.<token_secret>
# Used server-side only — never exposed to the browser
REGISTRY_READ_TOKEN=your_token_id.your_token_secret

# Comma-separated skill slugs shown on the landing page before any search
NEXT_PUBLIC_FEATURED_SLUGS=fastapi,architect-review,python-testing,ruff,uv
